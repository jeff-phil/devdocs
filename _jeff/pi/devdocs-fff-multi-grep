#!/usr/bin/env bash

show_help() {
        cat << EOF
Usage: `basename $0` <p1,p2,...> [options]
Options:

  -c, --constraints <...>   Path filter constraints, e.g. "python/, svelte/"
  -i, --ignore-case         Case-insensitive (default: smartCase)
      --context <N>         Context lines before and after each match
  -b, --before-context <N>  Lines before each match
  -a, --after-context <N>   Lines after each match
  -l, --limit <N>           Max matches per file (default: 50, max 100)
  -p, --page-size <N>       Number of matched files per page (default: 50)
  -n, --cursor <id>         Page number of results (default: 1, search returns next cursor number)

  --help                    Display this help message

Notes:
- Patterns are OR-logic comma separated multi-pattern content search, e.g. "type,decorator"
- Patterns are always literal** — there is no "--regex" flag
- Include all naming-convention variants** you care about: "foo_bar", "fooBar", "FooBar"
- Use "--constraints" for file filtering, especially to limit to specific docsets such as "python"
EOF
        exit 0
}

# Check for --help flag
for arg in "$@"; do
    if [[ "$arg" == "--help" ]]; then
        show_help
    fi
done

if [[ $# -eq 0 ]]; then
    show_help
fi

fff-multi-grep --sock /tmp/fff-devdocs.sock "$@" 2> /dev/null

if [[ $? -ne 0 ]]; then
    echo "Error occurred"
    echo 
    show_help
fi
